# Anthropic API key for LLM-powered RCA reasoning.
# If unset, Argus automatically falls back to its rule-based heuristic
# RCA engine so the whole project still runs end-to-end offline.
ANTHROPIC_API_KEY=

# Optional: real Slack incoming webhook URL. If unset, Argus prints
# incident summaries to the console instead of posting to Slack.
SLACK_WEBHOOK_URL=

# Set to "1" to auto-approve low-risk remediations without a human
# clicking approve (useful for demos / backtesting).
ARGUS_AUTO_APPROVE_LOW_RISK=1
